# Copy to backend/.env.lan and adjust if needed (optional).
# Used by scripts/lan-dev.sh automatically.

LAN_DEV=1
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.103.143
# Plain HTTP for LAN access (no certificate warnings)
LAN_ORIGIN=http://192.168.103.143:5173

# Redis for live monitor, Celery broker, and SMS prewarm cache.
# Required in production for workers + realtime SMS queue.
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_WORKER_CONCURRENCY=6

# Production: set DEBUG=0 so SMS never falls back to console logging.
# DEBUG=0
# DJANGO_SECRET_KEY=replace-me
